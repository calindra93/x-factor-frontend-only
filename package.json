{
  "name": "base44-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check:no-admin-in-dist": "node scripts/checkNoAdminInDist.mjs",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:all",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview",
    "check:spa-preview": "node scripts/ci/guard-spa-preview.mjs",
    "supabase:start": "supabase start",
    "supabase:reset": "supabase db reset --local",
    "supabase:stop": "supabase stop",
    "test:unit": "cross-env NODE_ENV=test vitest run --config vitest.config.js",
    "test:integration": "cross-env NODE_ENV=test vitest run --config vitest.integration.config.js",
    "test:all": "cross-env NODE_ENV=test node scripts/testAll.js",
    "simulate:turns": "node scripts/simulateTurns.js",
    "simulate:turns:ci": "node scripts/simulateTurns.js --turns 20 --seed 1337",
    "simulate:turns:long": "node scripts/simulateTurns.js --turns 200 --seed 1337 --report",
    "simulate:turn-engine": "node scripts/simulateTurnEngineTest.js",
    "fix:turn-countdown": "node scripts/fixTurnCountdown.js",
    "dev:startup": "node scripts/startDevEnv.js",
    "simulate:setup": "powershell -ExecutionPolicy Bypass -File scripts/setupAndRunSimulation.ps1 --test-only",
    "simulate:setup:full": "powershell -ExecutionPolicy Bypass -File scripts/setupAndRunSimulation.ps1",
    "simulate:env": "powershell -ExecutionPolicy Bypass -File scripts/getSupabaseKeys.ps1",
    "supabase:db:push:remote": "bash scripts/supabase/remote-db-push.sh",
    "local:bootstrap": "bash scripts/supabase/local-db-init.sh",
    "local:bootstrap:fresh": "bash scripts/supabase/local-db-init.sh --fresh"
  },
  "dependencies": {
    "@base44/sdk": "^0.8.18",
